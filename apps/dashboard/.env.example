NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional but recommended for local development
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/auth/role-redirect
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth/role-redirect

# Server-side proxy target for /api/auth/sync
BACKEND_API_URL=http://localhost:8000
# Optional fallback used by some client calls
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
