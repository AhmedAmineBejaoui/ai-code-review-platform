{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "type": "datasource", "pluginId": "prometheus" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "id": null,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "expr": "flower_workers_online", "legendFormat": "Online Workers", "refId": "A" }
      ],
      "title": "Online Workers",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "expr": "flower_tasks_by_state{state=\"PENDING\"}", "legendFormat": "Pending", "refId": "A" }
      ],
      "title": "Pending Tasks",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "expr": "flower_tasks_by_state{state=\"FAILURE\"}", "legendFormat": "Failed", "refId": "A" }
      ],
      "title": "Failed Tasks",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "id": 4,
      "targets": [
        { "expr": "flower_tasks_by_state{state=\"PENDING\"}", "legendFormat": "Pending", "refId": "A" },
        { "expr": "flower_tasks_by_state{state=\"STARTED\"}", "legendFormat": "Running", "refId": "B" },
        { "expr": "flower_tasks_by_state{state=\"SUCCESS\"}", "legendFormat": "Success", "refId": "C" },
        { "expr": "flower_tasks_by_state{state=\"FAILURE\"}", "legendFormat": "Failed", "refId": "D" }
      ],
      "title": "Tasks by State",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 5,
      "targets": [
        { "expr": "rate(flower_events_total[5m])", "legendFormat": "Events/s ({{type}})", "refId": "A" }
      ],
      "title": "Celery Event Rate (5m)",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 38,
  "tags": ["celery", "worker"],
  "templating": {
    "list": [{ "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus" }]
  },
  "title": "Celery Workers - AI Code Review",
  "uid": "celery-ai-review",
  "version": 1
}
