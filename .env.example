ENV=dev
BASE_URL=http://localhost:8000

# Database / Redis
DATABASE_URL=postgresql+psycopg://postgres:simplepass@localhost:5432/ai_code_review_platform
REDIS_URL=redis://localhost:6380/0

# Celery
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true
ANALYSIS_QUEUE_NAME=analyses
# On Windows, celery prefork can fail. Keep empty to auto-detect "solo" on Windows.
CELERY_WORKER_POOL=

# Webhook
GITHUB_WEBHOOK_SECRET=local-dev-secret

# Analysis limits and security
MAX_DIFF_BYTES=2000000
SECRET_SCAN_ENABLED=true
SECRET_SCAN_ENTROPY_THRESHOLD=3.8
SECRET_SCAN_MIN_TOKEN_LEN=20
SECRET_SCAN_MAX_FINDINGS=200
PURGE_RAW_DIFF_AFTER_REDACTION=true
ALLOW_UNSAFE_DIFF_API=false

# Static analysis
STATIC_ANALYSIS_ENABLED=true
STATIC_ANALYSIS_RUFF_ENABLED=true
STATIC_ANALYSIS_SEMGREP_ENABLED=true
STATIC_ANALYSIS_TIMEOUT_SECONDS=60
STATIC_ANALYSIS_MAX_FILES=200
STATIC_ANALYSIS_MAX_FINDINGS=200
STATIC_ANALYSIS_WORKSPACE_PATH=.
STATIC_ANALYSIS_AUTO_CHECKOUT_ENABLED=true
STATIC_ANALYSIS_REPO_HOST=github.com
STATIC_ANALYSIS_GIT_TOKEN=
STATIC_ANALYSIS_CHECKOUT_TIMEOUT_SECONDS=45
STATIC_ANALYSIS_CHECKOUT_BASE_PATH=
STATIC_ANALYSIS_FILTER_CHANGED_LINES=true
