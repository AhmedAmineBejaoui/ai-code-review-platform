ENV=dev
BASE_URL=http://localhost:8000

# ─── Database / Redis ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:simplepass@localhost:5432/ai_code_review_platform
REDIS_URL=redis://localhost:6380/0

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true
ANALYSIS_QUEUE_NAME=analyses
# On Windows, set to "solo". On Linux/macOS, leave empty to auto-detect prefork.
CELERY_WORKER_POOL=

# ─── GitHub Integration ───────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=local-dev-secret
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PEM=
GITHUB_API_BASE_URL=https://api.github.com

# ─── Diff Limits & Security ───────────────────────────────────────────────────
MAX_DIFF_BYTES=2000000
PURGE_RAW_DIFF_AFTER_REDACTION=true
ALLOW_UNSAFE_DIFF_API=false

# ─── Secret Scanning ──────────────────────────────────────────────────────────
SECRET_SCAN_ENABLED=true
SECRET_SCAN_ENTROPY_THRESHOLD=3.8
SECRET_SCAN_MIN_TOKEN_LEN=20
SECRET_SCAN_MAX_FINDINGS=200

# ─── Static Analysis ──────────────────────────────────────────────────────────
STATIC_ANALYSIS_ENABLED=true
STATIC_ANALYSIS_RUFF_ENABLED=true
STATIC_ANALYSIS_SEMGREP_ENABLED=true
STATIC_ANALYSIS_TIMEOUT_SECONDS=60
STATIC_ANALYSIS_MAX_FILES=200
STATIC_ANALYSIS_MAX_FINDINGS=200
STATIC_ANALYSIS_WORKSPACE_PATH=.
STATIC_ANALYSIS_AUTO_CHECKOUT_ENABLED=true
STATIC_ANALYSIS_REPO_HOST=github.com
STATIC_ANALYSIS_GIT_TOKEN=
STATIC_ANALYSIS_CHECKOUT_TIMEOUT_SECONDS=45
STATIC_ANALYSIS_CHECKOUT_BASE_PATH=
STATIC_ANALYSIS_FILTER_CHANGED_LINES=true

# ─── Secrets Encryption ───────────────────────────────────────────────────────
# Generate with: make generate-fernet-key
SECRETS_ENCRYPTION_KEY=
SECRETS_BOOTSTRAP_FROM_ENV=true

# ─── RBAC ─────────────────────────────────────────────────────────────────────
RBAC_ENFORCEMENT_ENABLED=false

# ─── Clerk Authentication (Backend API) ───────────────────────────────────────
# Enable this when frontend sends Clerk bearer tokens to backend endpoints.
CLERK_AUTH_ENABLED=false
# Example issuer: https://your-instance.clerk.accounts.dev
CLERK_ISSUER_URL=
# Optional override for JWKS endpoint. Leave empty to use {CLERK_ISSUER_URL}/.well-known/jwks.json
CLERK_JWKS_URL=
# Optional audience validation. Set if your Clerk JWT template includes aud.
CLERK_AUDIENCE=
CLERK_JWT_LEEWAY_SECONDS=10

# ─── LLM Integration (OpenAI) ─────────────────────────────────────────────────
# Set LLM_ENABLED=true and provide OPENAI_API_KEY to activate LLM review.
LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_PREDICT=400

# ─── Vector Store (Qdrant) ────────────────────────────────────────────────────
# Local: http://localhost:6333  (docker compose service: qdrant)
# Dashboard: http://localhost:6333/dashboard
QDRANT_ENABLED=false
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=code_review_rules
QDRANT_API_KEY=

# ─── Object Storage (MinIO / S3) ──────────────────────────────────────────────
# Local: localhost:9000  Console: http://localhost:9001  (minioadmin/minioadmin)
OBJECT_STORAGE_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-review-artifacts
MINIO_SECURE=false
